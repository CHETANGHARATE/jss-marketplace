# JSS Solutions Marketplace Frontend Environment Variables

# The base URL of the Laravel backend API
NEXT_PUBLIC_API_BASE_URL=https://api.jsssolutions.in/api/v1

# The URL of this frontend application
NEXT_PUBLIC_APP_URL=https://jss-marketplace.vercel.app

# Optional Google Analytics ID
NEXT_PUBLIC_GA_ID=

# Optional Sentry DSN
NEXT_PUBLIC_SENTRY_DSN=
